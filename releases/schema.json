{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alphaonedev.github.io/ai-memory-a2a-v0.6.3.1/releases/schema.json",
  "title": "ai-memory A2A campaign release summary (per-release)",
  "description": "Release-blocking schema for releases/<version>/summary.json. Validates two coexisting shapes via top-level `schema_version`: v1 = legacy gate-style flat verdict (used by archived runs and ship-gate parallels); v2 = First-Principles split where `substrate_verdict` and `nhi_verdict` are kept distinct per docs/governance.md Principle 1. The release-summary-gate.yml workflow validates this on every PR that touches releases/ and on every `v*` tag push. Schema authored 2026-05-01 alongside the v0.6.3.1 First-Principles refactor.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version"],
  "properties": {
    "schema_version": { "type": "integer", "enum": [1, 2] }
  },
  "oneOf": [
    {
      "$comment": "Schema v1 — legacy gate-style flat verdict. Kept for backward compatibility with archived runs and ship-gate parallel artifacts.",
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version", "version", "campaign_run_id", "pass_count", "fail_count", "wall_seconds", "verdict", "date"],
      "properties": {
        "schema_version":  { "const": 1 },
        "version":         { "type": "string", "pattern": "^v\\d+\\.\\d+\\.\\d+(?:\\.\\d+)?(?:-[A-Za-z0-9.-]+)?$" },
        "campaign_run_id": { "type": "string", "minLength": 1 },
        "date":            { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "wall_seconds":    { "type": "integer", "minimum": 0 },
        "pass_count":      { "type": "integer", "minimum": 0 },
        "fail_count":      { "type": "integer", "minimum": 0 },
        "verdict":         { "type": "string", "enum": ["pass", "fail"] },
        "headline":        { "type": "string" },
        "agent_group":     { "type": "string" },
        "tls_mode":        { "type": "string" },
        "cells":           { "type": "array" },
        "phases":          { "type": "array" }
      },
      "anyOf": [
        { "required": ["cells"] },
        { "required": ["phases"] }
      ]
    },
    {
      "$comment": "Schema v2 — First-Principles separation per docs/governance.md §1. substrate_verdict and nhi_verdict are distinct top-level keys (binary/reproducible vs behavioral/statistical evidence). cross_layer_consistency is a separate join surface. `version` + `verdict` are flat shims at top level for backward compatibility with release-summary-gate.yml — mirror subject.tag and a derived collapse of (substrate, nhi).",
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version", "version", "verdict", "subject", "campaign", "substrate_verdict", "nhi_verdict", "cross_layer_consistency", "funnel"],
      "properties": {
        "schema_version": { "const": 2 },
        "version":        { "type": "string", "pattern": "^v\\d+\\.\\d+\\.\\d+(?:\\.\\d+)?$" },
        "verdict":        { "type": "string", "enum": ["pending", "pass", "fail"] },
        "schema_change_notes": { "type": "array", "items": { "type": "string" } },
        "subject": {
          "type": "object",
          "additionalProperties": true,
          "required": ["repo", "tag", "schema"],
          "properties": {
            "repo":             { "type": "string", "minLength": 1 },
            "tag":              { "type": "string", "pattern": "^v\\d+\\.\\d+\\.\\d+(?:\\.\\d+)?$" },
            "tag_published_at": { "type": "string" },
            "schema":           { "type": "string", "pattern": "^v\\d+$" },
            "release_url":      { "type": "string" }
          }
        },
        "campaign": {
          "type": "object",
          "additionalProperties": true,
          "required": ["repo"],
          "properties": {
            "repo":             { "type": "string" },
            "governance_doc":   { "type": "string" },
            "phase_log_schema": { "type": "string" },
            "agent_scope":      { "type": "array", "items": { "type": "string" } },
            "out_of_scope":     { "type": "array", "items": { "type": "string" } },
            "scope_note":       { "type": "string" },
            "last_run_id":      { "type": ["string", "null"] },
            "superseded_runs":  { "type": "array" },
            "updated_at":       { "type": ["string", "null"] }
          }
        },
        "substrate_verdict": {
          "type": "object",
          "additionalProperties": true,
          "required": ["value", "phase", "evidence_type", "matrix", "scenarios"],
          "properties": {
            "value": { "type": "string", "enum": [
              "PENDING", "PASS", "FAIL", "PARTIAL — pending Patch 2",
              "HARNESS_INTEGRITY_FAILURE"
            ]},
            "expected_on_v0_6_3_1": { "type": "string" },
            "phase":         { "type": "integer", "const": 1 },
            "evidence_type": { "type": "string" },
            "matrix":        { "type": "object" },
            "scenarios":     { "type": "object" },
            "expected_red":  { "type": "array", "items": { "type": "string" } },
            "expected_red_rationale": { "type": "object" }
          }
        },
        "nhi_verdict": {
          "type": "object",
          "additionalProperties": true,
          "required": ["value", "phase", "evidence_type", "scenarios"],
          "properties": {
            "value": { "type": "string", "enum": [
              "PENDING", "PASS", "WEAK", "FAIL", "NEEDS_REVIEW", "NOT_APPLICABLE"
            ]},
            "phase":         { "type": "integer", "const": 3 },
            "evidence_type": { "type": "string" },
            "scenarios":     { "type": "object" },
            "phase4_analysis_path": { "type": ["string", "null"] }
          }
        },
        "cross_layer_consistency": {
          "type": "object",
          "additionalProperties": true,
          "required": ["value", "table"],
          "properties": {
            "value": { "type": "string", "enum": ["PENDING", "CONSISTENT", "INCONSISTENT"] },
            "table": { "type": "array" }
          }
        },
        "funnel": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "umbrella_issue":         { "type": ["string", "null"] },
            "patch_2_branch":         { "type": "string" },
            "patch_2_seed_issues":    { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  ]
}
